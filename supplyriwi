CREATE TABLE proveedores (
    id SERIAL PRIMARY KEY,
    nombre_proveedor VARCHAR(100) NOT NULL,
    nit_proveedor VARCHAR(20) UNIQUE NOT NULL,
    telefono_proveedor VARCHAR(20),
    email_proveedor VARCHAR(100) UNIQUE,
    ciudad_proveedor VARCHAR(100),
    pais_proveedor VARCHAR(100) NOT NULL
);

CREATE TABLE categorias (
    id SERIAL PRIMARY KEY,
    nombre_categoria VARCHAR(100) NOT NULL
);

CREATE TABLE sub_categorias (
    id SERIAL PRIMARY KEY,
    nombre_sub_categoria VARCHAR(100) NOT NULL,
    id_categoria INT NOT NULL,

    FOREIGN KEY (id_categoria)
        REFERENCES categorias(id)
);

CREATE TABLE bodegas (
    id SERIAL PRIMARY KEY,
    nombre_bodega VARCHAR(100) UNIQUE NOT NULL
);


CREATE TABLE unidades_medidas (
    id SERIAL PRIMARY KEY,
    unidad_medida VARCHAR(50) UNIQUE NOT NULL,
    abreviatura VARCHAR(10) UNIQUE NOT NULL
);

CREATE TABLE productos (
    id SERIAL PRIMARY KEY,
    nombre_producto VARCHAR(100) UNIQUE NOT NULL,
    descripcion_producto VARCHAR(100),
    id_unidad_medida INT NOT NULL,
    precio_unitario NUMERIC(10,2) NOT NULL,
    id_sub_categoria INT NOT NULL,

    FOREIGN KEY (id_unidad_medida)
        REFERENCES unidades_medidas(id),

    FOREIGN KEY (id_sub_categoria)
        REFERENCES sub_categorias(id)
);

CREATE TABLE compras (
    id_registro SERIAL PRIMARY KEY,
    fecha_compra DATE NOT NULL,
    id_producto INT NOT NULL,
    id_proveedor INT NOT NULL,
    cantidad_comprada INT NOT NULL,
    valor_total_compra NUMERIC(10,2) NOT NULL,
    id_bodega INT NOT NULL,

    FOREIGN KEY (id_producto)
        REFERENCES productos(id),

    FOREIGN KEY (id_proveedor)
        REFERENCES proveedores(id),

    FOREIGN KEY (id_bodega)
        REFERENCES bodegas(id)
);
