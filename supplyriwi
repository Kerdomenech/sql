/*consultas*/

/*Consulta 1.Inventario disponible por producto*/

SELECT
    p.nombre_producto,
    SUM(
        CASE
            WHEN m.tipo_movimiento = 'Entrada' THEN m.cantidad
            WHEN m.tipo_movimiento = 'Salida' THEN -m.cantidad
        END
    ) AS inventario_disponible
FROM productos p
INNER JOIN movimientos_inventario m
ON p.id_producto = m.id_producto
GROUP BY p.nombre_producto
ORDER BY inventario_disponible DESC;


/*CONSULTA 2. Productos almacenados por bodega*/

SELECT
    b.nombre_bodega,
    p.nombre_producto,
    SUM(
        CASE
            WHEN m.tipo_movimiento='Entrada' THEN m.cantidad
            WHEN m.tipo_movimiento='Salida' THEN -m.cantidad
        END
    ) AS cantidad
FROM movimientos_inventario m
INNER JOIN productos p
ON m.id_producto=p.id_producto
INNER JOIN bodegas b
ON m.id_bodega=b.id_bodega
GROUP BY
    b.nombre_bodega,
    p.nombre_producto
ORDER BY
    b.nombre_bodega;


/*CONSULTA 3. Total comprado por proveedor*/

SELECT
    pr.nombre_proveedor,
    SUM(dc.subtotal) AS total_comprado
FROM proveedores pr
INNER JOIN compras c
ON pr.id_proveedor=c.id_proveedor
INNER JOIN detalle_compras dc
ON c.id_compra=dc.id_compra
GROUP BY pr.nombre_proveedor
ORDER BY total_comprado DESC;


/*CONSULTA 4.Productos con menor existencia*/

SELECT
    p.nombre_producto,
    SUM(
        CASE
            WHEN m.tipo_movimiento='Entrada' THEN m.cantidad
            WHEN m.tipo_movimiento='Salida' THEN -m.cantidad
        END
    ) AS existencia
FROM productos p
INNER JOIN movimientos_inventario m
ON p.id_producto=m.id_producto
GROUP BY p.nombre_producto
ORDER BY existencia ASC
LIMIT 5;


/*CONSULTA 5.Cinco productos más comprados*/

SELECT
    p.nombre_producto,
    SUM(dc.cantidad) AS total_comprado
FROM detalle_compras dc
INNER JOIN productos p
ON dc.id_producto=p.id_producto
GROUP BY p.nombre_producto
ORDER BY total_comprado DESC
LIMIT 5;


/*CONSULTA 6.Valor económico del inventario por ciudad*/

SELECT
    b.ciudad_bodega,
    SUM(
        CASE
            WHEN m.tipo_movimiento='Entrada'
                THEN m.cantidad*p.precio_unitario
            WHEN m.tipo_movimiento='Salida'
                THEN -m.cantidad*p.precio_unitario
        END
    ) AS valor_inventario
FROM movimientos_inventario m
INNER JOIN productos p
ON m.id_producto=p.id_producto
INNER JOIN bodegas b
ON m.id_bodega=b.id_bodega
GROUP BY b.ciudad_bodega
ORDER BY valor_inventario DESC;


/*CONSULTA 7.Lista de productos con categoría y subcategoría*/

SELECT
    p.nombre_producto,
    c.nombre_categoria,
    s.nombre_sub_categoria,
    p.precio_unitario
FROM productos p
INNER JOIN sub_categorias s
ON p.id_sub_categoria=s.id_sub_categoria
INNER JOIN categorias c
ON s.id_categoria=c.id_categoria;


/*CONSULTA 8.Proveedores con ciudad*/

SELECT
    pr.nombre_proveedor,
    c.nombre_ciudad,
    c.pais
FROM proveedores pr
INNER JOIN ciudades c
ON pr.id_ciudad=c.id_ciudad;


/*CONSULTA 9.Total de productos registrados*/

SELECT
COUNT(*) AS total_productos
FROM productos;


/*CONSULTA 10.Precio promedio de los productos*/

SELECT
AVG(precio_unitario) AS precio_promedio
FROM productos;


/* CONSULTA 11.Producto más costoso*/

SELECT
nombre_producto,
precio_unitario
FROM productos
ORDER BY precio_unitario DESC
LIMIT 1;


/*CONSULTA 12 .Producto más económico*/

SELECT
nombre_producto,
precio_unitario
FROM productos
ORDER BY precio_unitario ASC
LIMIT 1;


/*CONSULTA 14.Cantidad de productos por categorí*/

SELECT
    c.nombre_categoria,
    COUNT(*) AS cantidad
FROM productos p
INNER JOIN sub_categorias s
ON p.id_sub_categoria=s.id_sub_categoria
INNER JOIN categorias c
ON s.id_categoria=c.id_categoria
GROUP BY c.nombre_categoria
ORDER BY cantidad DESC;

/* CONSULTA 14.Compras realizadas con proveedor*/

SELECT
    co.id_compra,
    co.fecha_compra,
    pr.nombre_proveedor
FROM compras co
INNER JOIN proveedores pr
ON co.id_proveedor=pr.id_proveedor
ORDER BY co.fecha_compra;


/*CONSULTA 15.Detalle completo de las compras*/

SELECT
    co.id_compra,
    co.fecha_compra,
    pr.nombre_proveedor,
    pd.nombre_producto,
    dc.cantidad,
    dc.precio_compra,
    dc.subtotal
FROM detalle_compras dc
INNER JOIN compras co
ON dc.id_compra=co.id_compra
INNER JOIN proveedores pr
ON co.id_proveedor=pr.id_proveedor
INNER JOIN productos pd
ON dc.id_producto=pd.id_producto
ORDER BY co.id_compra;


